@page
@model QuanLyySinhVien.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container" style="max-width:540px;margin:4rem auto">
    <div class="card shadow-sm">
        <div class="card-header bg-white text-center"><h4>Quên mật khẩu</h4></div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email hoặc tên đăng nhập</label>
                    <input asp-for="Identifier" class="form-control" />
                    <span asp-validation-for="Identifier" class="text-danger"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Gửi yêu cầu</button>
                </div>
            </form>

            @if (!string.IsNullOrEmpty(Model.ResetLink))
            {
                <div class="alert alert-info mt-3">Link reset (demo): <a href="@Model.ResetLink">@Model.ResetLink</a></div>
            }

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert alert-success mt-3">@Model.Message</div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
            }
        </div>
    </div>
</div>