@page
@model QuanLyySinhVien.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container" style="max-width:540px;margin:4rem auto">
    <div class="card shadow-sm">
        <div class="card-header bg-white text-center"><h4>Đặt lại mật khẩu</h4></div>
        <div class="card-body">
            @if (!Model.ValidToken)
            {
                <div class="alert alert-danger">Token không hợp lệ hoặc đã hết hạn.</div>
            }
            else
            {
                <form method="post">
                    <input type="hidden" asp-for="Token" />
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Lưu</button>
                    </div>
                </form>
            }

            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert alert-success mt-3">@Model.Message</div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
            }
        </div>
    </div>
</div>